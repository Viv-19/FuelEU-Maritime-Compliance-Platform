{
  "name": "fueleu-backend",
  "version": "1.0.0",
  "description": "FuelEU Maritime Compliance Platform — Backend API",
  "main": "dist/infrastructure/server/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/infrastructure/server/server.ts",
    "build": "tsc",
    "start": "node dist/infrastructure/server/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "db:migrate": "ts-node src/infrastructure/db/runMigrations.ts",
    "db:seed": "ts-node src/infrastructure/db/runSeeds.ts"
  },
  "keywords": [
    "fueleu",
    "maritime",
    "compliance"
  ],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "pg": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
